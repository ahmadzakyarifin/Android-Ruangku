<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/outline"
    app:strokeWidth="1.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@android:color/transparent">

        <TextView
            android:id="@+id/txtJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Judul Catatan"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:textColor="@color/onSurface"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnDelete"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Meeting proyek" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            app:tint="@color/onSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/txtJudul" />

        <TextView
            android:id="@+id/txtCatatan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Isi catatan..."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/onSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtJudul"
            tools:text="Membahas progress pengembangan fitur baru." />

        <!-- BARIS CHIPS: STATUS, KATEGORI, PRIORITAS -->
        <com.google.android.material.chip.Chip
            android:id="@+id/txtStatus"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="33dp"
            android:layout_marginTop="12dp"
            android:text="Aktif"
            android:textSize="10sp"
            app:chipCornerRadius="6dp"
            app:chipBackgroundColor="@android:color/transparent"
            app:chipStrokeColor="@color/outline"
            app:chipStrokeWidth="1.5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtCatatan" />

        <com.google.android.material.chip.Chip
            android:id="@+id/txtKategori"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="33dp"
            android:layout_marginStart="6dp"
            android:text="Kuliah"
            android:textSize="10sp"
            app:chipCornerRadius="6dp"
            app:chipBackgroundColor="@android:color/transparent"
            app:chipStrokeColor="@color/outline"
            app:chipStrokeWidth="1.5dp"
            app:chipIcon="@drawable/ic_category"
            app:chipIconVisible="true"
            app:chipIconSize="14dp"
            app:chipIconTint="@color/onSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/txtStatus"
            app:layout_constraintTop_toTopOf="@id/txtStatus" />

        <com.google.android.material.chip.Chip
            android:id="@+id/txtPrioritas"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="33dp"
            android:layout_marginStart="6dp"
            android:text="Tinggi"
            android:textSize="10sp"
            app:chipCornerRadius="6dp"
            app:chipBackgroundColor="@android:color/transparent"
            app:chipStrokeColor="@color/outline"
            app:chipStrokeWidth="1.5dp"
            app:chipIcon="@drawable/ic_priority"
            app:chipIconVisible="true"
            app:chipIconSize="14dp"
            app:chipIconTint="@color/onSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/txtKategori"
            app:layout_constraintTop_toTopOf="@id/txtKategori" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@id/txtPrioritas"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/txtPrioritas"
            app:layout_constraintTop_toTopOf="@id/txtPrioritas">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/onSurfaceVariant" />

            <TextView
                android:id="@+id/txtTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12/04/2025"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/onSurfaceVariant"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
